PORT=3000

# Base compartida del ecosistema Offal (controletiquetas). Este sistema usa el
# esquema `compras` y lee la identidad del padrón `acceso`.
# En Azure ya existen las AZURE_SQL_*; el código las toma por fallback.
DB_SERVER=
DB_NAME=controletiquetas
DB_USER=
DB_PASS=
DB_PORT=1433
DB_ENCRYPT=true

# Rol simulado en desarrollo (sin Easy Auth delante): ADMIN | GESTOR | LECTOR.
DEV_USER_ROLE=ADMIN

# Carpeta de los PDFs. En App Service apuntar a /home (único disco persistente).
# UPLOAD_DIR=/home/data/contratos
